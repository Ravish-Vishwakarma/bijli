{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bijli",
  "version": "0.1.0",
  "identifier": "com.ramdeenpc.bijli",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "bijli",
        "width": 800,
        "height": 650,
        "transparent": true,
        "decorations": false,
        "center": true,
        "skipTaskbar": true,
        "resizable": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}